# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1

# Cloud Storage
GCS_BUCKET_NAME=komatsuna-ai-agent-dev

# Firestore
FIRESTORE_DATABASE=(default)

# Vertex AI / Gemini
VERTEX_AI_LOCATION=asia-northeast1
GEMINI_MODEL=gemini-2.0-flash

# Cloud Run
AGENT_API_URL=https://agent-api-xxxxx-an.a.run.app

# LINE Messaging API（将来利用）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_WEBHOOK_VERIFY_TOKEN=

# Raspberry Pi / エッジ
ARDUINO_SERIAL_PORT=/dev/ttyACM0
ARDUINO_BAUD_RATE=115200
ALLOW_WATER_COMMAND_FROM_PI=false
DRY_RUN_MODE=true
CAMERA_ENABLED=true
EXPERIMENT_ROUND_ID=round_1
PLANTER_PROFILE_ID=ai_planter_a
LOCAL_DATA_DIR=./data/local
OBSERVATION_INTERVAL_MINUTES=60

# 天気 API（バッチ用）
WEATHER_API_KEY=
WEATHER_LOCATION_LAT=35.6812
WEATHER_LOCATION_LON=139.7671

# アプリケーション
LOG_LEVEL=INFO
ENVIRONMENT=dev
